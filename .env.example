# =============================================================================
# IdeaSpeak environment matrix
# Copy to .env.local for local dev. Never commit real secrets.
# See docs/API_SETUP.md for Vercel + Railway production setup.
# =============================================================================

# -----------------------------------------------------------------------------
# xAI Grok (required for Real Grok)
# Vercel Production: ✅  |  Railway: ✅  |  Local: .env.local or Settings UI
# Get key: https://console.x.ai/
# -----------------------------------------------------------------------------
XAI_API_KEY=xai-your-key-here
# Optional model overrides
# XAI_CHAT_MODEL=grok-3
# XAI_BUILD_MODEL=grok-4.5

# -----------------------------------------------------------------------------
# E2B sandbox (optional — Sprint 3)
# Vercel: —  |  Railway: ✅  |  Local: .env.local
# Get key: https://e2b.dev/
# -----------------------------------------------------------------------------
# E2B_API_KEY=e2b_your-key-here

# -----------------------------------------------------------------------------
# Stripe (optional — payments / Ship tier)
# Vercel: —  |  Railway: ✅  |  Local: .env.local + Stripe CLI for webhooks
# Dashboard: https://dashboard.stripe.com/test/products
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...   # Pro $29/mo recurring price ID
# STRIPE_TEAM_PRICE_ID=price_...  # Team $79/mo recurring price ID

# -----------------------------------------------------------------------------
# Supabase (optional — persistence / auth — Sprint 4)
# Vercel: ✅ (anon key only)  |  Railway: ✅ (service key)  |  Local: .env.local
# Create project: https://supabase.com/dashboard/new/project
# Run supabase/schema.sql in SQL Editor after creating the project.
# -----------------------------------------------------------------------------
# Browser (Vite) — safe to expose anon key; enable RLS in schema.sql
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Server (Railway / Bun) — never expose service role to the browser
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Frontend → API routing
# Vercel Production: leave empty (same-origin /api/* serverless)
# Railway: set to your Railway service URL (voice + long-running routes)
# Local dev: leave empty — Vite proxies /api → localhost:3001
# -----------------------------------------------------------------------------
# VITE_API_BASE=

# -----------------------------------------------------------------------------
# Bun server (Railway / local backend)
# -----------------------------------------------------------------------------
PORT=3001